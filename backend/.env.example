# MongoDB Connection
# Option 1: Use components (Recommended for automatic RFC 3986 escaping)
MONGO_USER=tirthsavsani7_db_user
MONGO_PASSWORD=Tirth@2606
MONGO_HOST=firstcluster.gtqxbfb.mongodb.net
MONGO_DB_NAME=trading_platform
MONGO_OPTIONS=retryWrites=true&w=majority&appName=FirstCluster

# Option 2: Use explicit URI (Not recommended if password contains special characters)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/trading_platform?retryWrites=true&w=majority

# SocketIO Configuration
# Options: eventlet, threading, gevent
SOCKET_ASYNC_MODE=eventlet
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/3

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000
FRONTEND_URL=http://localhost:5173
HOST=0.0.0.0

# JWT Configuration (Generate a secure key for production)
JWT_SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-characters
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Security (Generate a new secret key for production)
SECRET_KEY=change-this-to-another-secure-random-string

# Redis (optional - for caching and rate limiting)
REDIS_URL=redis://localhost:6379/0

# Trading Configuration
TRADING_MODE=paper
PAPER_BALANCE=100000

# Risk Management
RISK_MAX_DAILY_LOSS_PERCENT=5.0
RISK_PER_TRADE_PERCENT=1.0
RISK_MAX_OPEN_POSITIONS=3
RISK_MAX_CONSECUTIVE_LOSSES=3
RISK_MAX_DRAWDOWN_PERCENT=10.0
RISK_TRADE_COOLDOWN_MINUTES=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
CORS_ORIGINS=*

# Rate Limiting
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=100/minute

# Owner Credentials (for initial admin)
OWNER_USERNAME=admin
# Use bcrypt to hash your password and paste the hash here
# Owner password hash - generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
OWNER_PASSWORD_HASH=

# Encryption Key (for encrypting sensitive data)
# Generate with: python -c "import base64; import os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=