# =============================================================================
# PRODUCTION ENVIRONMENT FILE
# =============================================================================
# Copy this file to .env and update with your values
# NEVER commit .env to version control

# =============================================================================
# FLASK CONFIGURATION
# =============================================================================
FLASK_ENV=production
FLASK_DEBUG=0
PORT=5000
HOST=0.0.0.0

# =============================================================================
# DATABASE - MONGODB
# =============================================================================
MONGO_USER=trading_admin
MONGO_PASSWORD=generate-a-secure-password-here
MONGO_DB_NAME=trading_db
MONGO_URI=mongodb://trading_admin:generate-a-secure-password-here@mongodb:27017/trading_db?authSource=admin

# =============================================================================
# REDIS
# =============================================================================
REDIS_PASSWORD=generate-a-secure-redis-password
REDIS_URL=redis://:generate-a-secure-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:generate-a-secure-redis-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:generate-a-secure-redis-password@redis:6379/2
SOCKETIO_MESSAGE_QUEUE=redis://:generate-a-secure-redis-password@redis:6379/3

# =============================================================================
# SECURITY - CRITICAL
# =============================================================================
# Generate with: python -c "import os; print(os.urandom(32).hex())"
SECRET_KEY=generate-64-char-hex-secret-key-here

# Generate with: python -c "import os; print(os.urandom(32).hex())"
JWT_SECRET_KEY=generate-64-char-hex-jwt-secret-here

# Generate with: python -c "import base64; import os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# =============================================================================
# CORS - CONFIGURE FOR PRODUCTION
# =============================================================================
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# =============================================================================
# RATE LIMITING
# =============================================================================
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=100/minute

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
TRADING_MODE=paper
PAPER_BALANCE=100000

# =============================================================================
# RISK MANAGEMENT
# =============================================================================
RISK_MAX_DAILY_LOSS_PERCENT=5.0
RISK_PER_TRADE_PERCENT=1.0
RISK_MAX_OPEN_POSITIONS=3
RISK_MAX_CONSECUTIVE_LOSSES=3
RISK_MAX_DRAWDOWN_PERCENT=10.0
RISK_TRADE_COOLDOWN_MINUTES=5

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# ADMIN CREDENTIALS
# =============================================================================
OWNER_USERNAME=admin
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
OWNER_PASSWORD_HASH=